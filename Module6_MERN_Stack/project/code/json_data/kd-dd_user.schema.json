{
	"$schema": "http://json-schema.org/draft-07/schema",
	"title": "MongoDB data schema for KD-DD",
	"description": "This is a schema for the Users collection. It will be used for data validation at the level when the data comes in from the frontend and at the level prior to adding/updating data to the database.",
	"type": "object",
	"properties": {
		"_id": {
			"type": "string"
		},
		"AccountInfo": {
			"type": "object",
			"properties": {
				"UserName": {
					"type": "string",
					"description": "Login name information of the user in the form of their email.",
					"pattern": "^([a-zA-Z0-9_\\-\\.]+)@([a-zA-Z0-9_\\-\\.]+)\\.([a-zA-Z]{2,5})$"
				},
				"UserPassword": {
					"type": "string",
					"description": "Login password information in the form of plain text, but that will be stored in the database as a hash using the bcrypt algorithm",
					"minLength": 8,
					"maxLength": 24
				}
			},
			"required": ["UserName", "UserPassword"],
			"additionalProperties": false
		},
		"UserProfile": {
			"type": "object",
			"properties": {
				"FirstName": {
					"type": "string"
				},
				"MiddleName": {
					"type": "string"
				},
				"FamilyName": {
					"type": "string"
				},
				"PhoneNumber": {
					"type": "string",
					"pattern": "^([2-9]\\d{2}[2-9]\\d{7}|[2-9]\\d{2}-[2-9]\\d{2}-\\d{4})$"
				},
				"EmailAddress": {
					"type": "string",
					"pattern": "^([a-zA-Z0-9_\\-\\.]+)@([a-zA-Z0-9_\\-\\.]+)\\.([a-zA-Z]{2,})$"
				}
			},
			"required": ["FirstName", "FamilyName"],
			"anyOf": [{ "required": ["PhoneNumber"] }, { "required": ["EmailAddress"] }],
			"additionalProperties": false
		},
		"CreditCardDetails": {
			"type": "array",
			"description": "An array of saved user credit cards. Currently, only VISA and MasterCard are accepted.",
			"items": {
				"type": "object",
				"properties": {
					"_id": {
						"type": "string"
					},
					"IsDefault": {
						"type": "boolean",
						"description": "True if this card should be automatically selected at checkout."
					},
					"CC_Name": {
						"type": "string"
					},
					"CC_Type": {
						"type": "string",
						"enum": ["VISA", "MasterCard"]
					},
					"CC_Number": {
						"type": "string",
						"minLength": 15,
						"maxLength": 16,
						"pattern": "^(4\\d{15}|5[1-5]\\d{14}|2(22[1-9]|2[3-9]\\d|[3-6]\\d{2}|7[0-1]\\d|720)\\d{12})$"
					},
					"CC_ExpMonth": {
						"type": "string",
						"description": "Two-digit expiration month (01-12)",
						"pattern": "^(0[1-9]|1[0-2])$"
					},
					"CC_ExpYear": {
						"type": "string",
						"description": "Four-digit expiration year (2000)",
						"pattern": "^(\\d{4})$"
					}
				},
				"required": [
					"IsDefault",
					"CC_Type",
					"CC_Number",
					"CC_Name",
					"CC_ExpMonth",
					"CC_ExpYear"
				],
				"additionalProperties": false
			}
		},
		"VehicleDetails": {
			"type": "array",
			"description": "An array of user vehicles. Each one includes details about the vehicle including the vehicle owner.",
			"items": {
				"type": "object",
				"properties": {
					"_id": {
						"type": "string"
					},
					"OwnerName": {
						"type": "string"
					},
					"VehicleMake": {
						"type": "string"
					},
					"VehicleModel": {
						"type": "string"
					},
					"VehicleColour": {
						"type": "string"
					},
					"LicensePlate": {
						"type": "string",
						"pattern": "^([A-Z]{4}\\d{3}|[A-Z]{3}\\d{3}|[A-Z]{2}\\d{5}|GV[A-Z]\\d{4}|[A-Z0-9]{2,8})$"
					}
				},
				"required": ["VehicleMake", "VehicleModel", "LicensePlate"],
				"additionalProperties": false
			}
		},
		"additionalProperties": false
	},
	"required": ["AccountInfo", "UserProfile", "CreditCardDetails", "VehicleDetails"],
	"additionalProperties": false
}
